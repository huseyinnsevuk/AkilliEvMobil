<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AkilliEvMobil.Views"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="AkilliEvMobil.Views.SettingsPage"
             Title="Ayarlar"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             ios:Page.UseSafeArea="False"
             BackgroundColor="#F5F7FA">
    
    <Grid RowDefinitions="Auto, *, Auto" BackgroundColor="#F5F7FA">
        <!-- HEADER (PROFILE SECTION) -->
        <VerticalStackLayout Grid.Row="0" Padding="0,30,0,30" Spacing="7" HorizontalOptions="Center">
            <Border WidthRequest="70" HeightRequest="70" HorizontalOptions="Center" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="50" /></Border.StrokeShape>
                <Image Source="user.png" Aspect="AspectFill" />
            </Border>
            
            <Label Text="Hüseyin Sevuk" 
                   x:Name="UserNameLabel"
                   FontSize="22" 
                   FontAttributes="Bold" 
                   TextColor="#1E293B" 
                   HorizontalOptions="Center" />
            
            <Label Text="huseyin@example.com" 
                   x:Name="UserEmailLabel"
                   FontSize="14" 
                   TextColor="#64748B" 
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="30">
                
                <!-- ACCOUNT SETTINGS SECTION -->
                <VerticalStackLayout Spacing="15">
                    <Label Text="Hesap Ayarları" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" Margin="10,0" />
                    
                    <Border BackgroundColor="White" StrokeThickness="0" Padding="5">
                        <Border.StrokeShape><RoundRectangle CornerRadius="25" /></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="#000000" Offset="0,4" Radius="15" Opacity="0.05" /></Border.Shadow>
                        
                        <VerticalStackLayout>
                            <!-- Personal Information -->
                            <Grid ColumnDefinitions="60, *, 40" Padding="15" HeightRequest="65">
                                <Image Grid.Column="0" Source="user_pen.png" HeightRequest="22" WidthRequest="22" VerticalOptions="Center" HorizontalOptions="Center">
                                    <Image.Behaviors>
                                        <!-- İkon Rengini Tintlemek için (Opsiyonel) -->
                                    </Image.Behaviors>
                                </Image>
                                <Label Grid.Column="1" Text="Kişisel Bilgiler" VerticalOptions="Center" TextColor="#334155" FontSize="15" />
                                <Label Grid.Column="2" Text="›" FontSize="24" TextColor="#CBD5E1" VerticalOptions="Center" HorizontalOptions="Center" />
                            </Grid>
                            
                            <BoxView HeightRequest="1" Color="#F1F5F9" Margin="65,0,20,0" />

                            <!-- Change Password -->
                            <Grid ColumnDefinitions="60, *, 40" Padding="15" HeightRequest="65">
                                <Image Grid.Column="0" Source="lock.png" HeightRequest="22" WidthRequest="22" VerticalOptions="Center" HorizontalOptions="Center" />
                                <Label Grid.Column="1" Text="Şifreyi Değiştir" VerticalOptions="Center" TextColor="#334155" FontSize="15" />
                                <Label Grid.Column="2" Text="›" FontSize="24" TextColor="#CBD5E1" VerticalOptions="Center" HorizontalOptions="Center" />
                            </Grid>

                            <BoxView HeightRequest="1" Color="#F1F5F9" Margin="65,0,20,0" />

                            <!-- Manage Subscription -->
                            <Grid ColumnDefinitions="60, *, 40" Padding="15" HeightRequest="65">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnManageSubscriptionClicked" />
                                </Grid.GestureRecognizers>
                                <Image Grid.Column="0" Source="credit_card.png" HeightRequest="22" WidthRequest="22" VerticalOptions="Center" HorizontalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="Aboneliği Yönet" TextColor="#334155" FontSize="15" />
                                    <Label x:Name="CurrentPlanLabel" Text="Basic Paket" FontSize="11" TextColor="#4A90E2" FontAttributes="Bold" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="›" FontSize="24" TextColor="#CBD5E1" VerticalOptions="Center" HorizontalOptions="Center" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- GENERAL SETTINGS SECTION -->
                <VerticalStackLayout Spacing="15">
                    <Label Text="Genel Ayarlar" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" Margin="10,0" />
                    
                    <Border BackgroundColor="White" StrokeThickness="0" Padding="5">
                        <Border.StrokeShape><RoundRectangle CornerRadius="25" /></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="#000000" Offset="0,4" Radius="15" Opacity="0.05" /></Border.Shadow>
                        
                        <VerticalStackLayout>
                            <!-- Notification Preferences -->
                            <Grid ColumnDefinitions="60, *, Auto" Padding="15" HeightRequest="65">
                                <Image Grid.Column="0" Source="bell.png" HeightRequest="22" WidthRequest="22" VerticalOptions="Center" HorizontalOptions="Center" />
                                <Label Grid.Column="1" Text="Bildirim Tercihleri" VerticalOptions="Center" TextColor="#334155" FontSize="15" />
                                <Switch Grid.Column="2" IsToggled="True" OnColor="#4A90E2" VerticalOptions="Center" Scale="0.8" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ÇIKIŞ YAP -->
                <Button Text="Çıkış Yap" 
                        TextColor="#EF4444" 
                        BackgroundColor="Transparent" 
                        FontAttributes="Bold" 
                        FontSize="16"
                        Clicked="OnLogoutClicked"
                        Margin="0,10,0,40" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- YENİ MODÜLER CUSTOM TAB BAR KONTROLÜ -->
        <local:CustomTabBar Grid.Row="2" ActiveTab="Settings" />
    </Grid>
</ContentPage>
