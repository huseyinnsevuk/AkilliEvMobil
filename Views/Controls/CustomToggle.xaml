<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AkilliEvMobil.Views.Controls.CustomToggle">

    <Grid WidthRequest="54" HeightRequest="28">
        <!-- Background Capsule -->
        <Border x:Name="BackgroundBorder" StrokeThickness="0" HorizontalOptions="Fill" VerticalOptions="Fill">
            <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
            <Border.Background>
                <LinearGradientBrush x:Name="ActiveGradient" StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#4ADE80" Offset="0.0" /> <!-- Greenish -->
                    <GradientStop Color="#3B82F6" Offset="1.0" /> <!-- Blue -->
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Thumb -->
        <Border x:Name="Thumb" 
                BackgroundColor="White" 
                WidthRequest="22" 
                HeightRequest="22" 
                HorizontalOptions="Start" 
                Margin="3,0" 
                VerticalOptions="Center" 
                StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="11" /></Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.15" />
            </Border.Shadow>
        </Border>

        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnToggled" />
        </Grid.GestureRecognizers>
    </Grid>
</ContentView>
