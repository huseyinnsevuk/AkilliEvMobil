<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AkilliEvMobil.Views"
             x:Class="AkilliEvMobil.Views.TentPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#F5F7FA">

    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="15,40,15,20" BackgroundColor="#F5F7FA" ZIndex="1">
            <Border Grid.Column="0" HeightRequest="44" WidthRequest="44" BackgroundColor="White" StrokeThickness="0" HorizontalOptions="Start" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape>
                <Border.Shadow><Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.05" /></Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked" />
                </Border.GestureRecognizers>
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="Scale" Value="0.9" />
                                    <Setter Property="BackgroundColor" Value="#F0F3F8" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
                <Image Source="back.png" HeightRequest="18" WidthRequest="18" TranslationX="-3" VerticalOptions="Center" HorizontalOptions="Center" InputTransparent="True" />
            </Border>
            <Label Grid.Column="1" Text="Tente" FontFamily="Quicksand" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#1E293B" />
            <BoxView Grid.Column="2" WidthRequest="44" BackgroundColor="Transparent" />
        </Grid>

        <!-- Scrollable Content -->
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="0,0,0,100" Spacing="30">
                
                <!-- Tent Image -->
                <Grid VerticalOptions="Center" HorizontalOptions="Center" Margin="0,10">
                    <Border StrokeThickness="0" BackgroundColor="Transparent">
                        <Image Source="tent.png" HeightRequest="180" Aspect="AspectFit" />
                    </Border>
                </Grid>

                <!-- Operation Speed (Çalışma Hızı) -->
                <VerticalStackLayout Spacing="15" Padding="25,0">
                    <Label Text="Çalışma Hızı" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" />
                    <Grid ColumnDefinitions="*, *, *, *" ColumnSpacing="10">
                        <Button x:Name="Btn25" Grid.Column="0" Text="%25" Clicked="OnSpeedPresetClicked" Style="{StaticResource PresetButtonStyle}" />
                        <Button x:Name="Btn50" Grid.Column="1" Text="%50" Clicked="OnSpeedPresetClicked" Style="{StaticResource PresetButtonStyle}" />
                        <Button x:Name="Btn75" Grid.Column="2" Text="%75" Clicked="OnSpeedPresetClicked" Style="{StaticResource PresetButtonStyle}" />
                        <Button x:Name="Btn100" Grid.Column="3" Text="%100" Clicked="OnSpeedPresetClicked" Style="{StaticResource PresetButtonStyle}" />
                    </Grid>
                </VerticalStackLayout>

                <!-- Control Buttons (Yukarı / Aşağı) -->
                <Grid ColumnDefinitions="*, *" ColumnSpacing="20" Padding="25,0">
                    <!-- Yukarı -->
                    <Border Grid.Column="0" HeightRequest="160" Stroke="White" StrokeThickness="1.5">
                        <Border.StrokeShape><RoundRectangle CornerRadius="30" /></Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E6FFFFFF" Offset="0.0" />
                                <GradientStop Color="#CCDFE5F0" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,6" Radius="15" Opacity="0.08" /></Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnUpTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                            <Image Source="updown.png" Rotation="180" HeightRequest="50" WidthRequest="50" HorizontalOptions="Center" />
                            <Label Text="Yukarı" FontSize="16" FontAttributes="Bold" TextColor="#1E293B" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Aşağı -->
                    <Border Grid.Column="1" HeightRequest="160" Stroke="White" StrokeThickness="1.5">
                        <Border.StrokeShape><RoundRectangle CornerRadius="30" /></Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E6FFFFFF" Offset="0.0" />
                                <GradientStop Color="#CCDFE5F0" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,6" Radius="15" Opacity="0.08" /></Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDownTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                            <Image Source="updown.png" HeightRequest="50" WidthRequest="50" HorizontalOptions="Center" />
                            <Label Text="Aşağı" FontSize="16" FontAttributes="Bold" TextColor="#1E293B" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Status Info -->
                <Border Margin="25,10,25,0" BackgroundColor="#FFFFFF" StrokeThickness="0" Padding="20">
                    <Border.StrokeShape><RoundRectangle CornerRadius="25" /></Border.StrokeShape>
                    <Border.Shadow><Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.03" /></Border.Shadow>
                    <Label x:Name="StatusLabel" Text="Açıklık derecesi: %50" FontSize="16" FontAttributes="Bold" TextColor="#4A90E2" HorizontalOptions="Center" />
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="PresetButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="TextColor" Value="#1E293B" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="15" />
                <Setter Property="HeightRequest" Value="50" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="BorderWidth" Value="0" />
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#54BDFF" Offset="0.0" />
                                                <GradientStop Color="#0042C7" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="TextColor" Value="White" />
                                    <Setter Property="Scale" Value="0.95" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>
</ContentPage>
