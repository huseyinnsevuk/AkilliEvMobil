<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ios="clr-namespace:Microsoft.Maui.Controls.PlatformConfiguration.iOSSpecific;assembly=Microsoft.Maui.Controls"
             x:Class="AkilliEvMobil.Views.SubscriptionPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             ios:Page.UseSafeArea="False"
             BackgroundColor="#F5F7FA">

    <Grid RowDefinitions="Auto, *, Auto">
        <!-- Tam Ekran Arka Plan -->
        <BoxView Grid.RowSpan="3" BackgroundColor="#F5F7FA" Margin="0" />

        <!-- ÜST BAŞLIK -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *" Padding="20,52,20,10">

            <!-- DAİRESEL GERİ BUTONU -->
            <Border Grid.Column="0"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    WidthRequest="42"
                    HeightRequest="42"
                    VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="21" /></Border.StrokeShape>
                <Border.Shadow><Shadow Brush="#000000" Offset="0,2" Radius="10" Opacity="0.10" /></Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked" />
                </Border.GestureRecognizers>
                <Label Text="&#x2039;"
                       FontSize="26"
                       TextColor="#4F46E5"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       FontAttributes="Bold"
                       Margin="-2,0,0,0" />
            </Border>

            <Label Grid.Column="1"
                   Text="Abonelik Planı"
                   FontSize="17"
                   FontAttributes="Bold"
                   TextColor="#1E293B"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"
                   Margin="0,0,42,0" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- BASIC VIEW -->
                <VerticalStackLayout x:Name="BasicView" IsVisible="True">

                    <!-- BAŞLIK -->
                    <VerticalStackLayout Padding="28,16,28,20" Spacing="10">
                        <Label Text="Daha Fazlasını Keşfet.&#x0a;Premium'a Geç."
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="#0F172A"
                               LineHeight="1.25" />
                        <Label Text="Akıllı evinizin tüm gücünü ortaya çıkaran özel avantajların keyfini çıkarın."
                               FontSize="14"
                               TextColor="#64748B"
                               LineHeight="1.45" />
                    </VerticalStackLayout>

                    <!-- DIŞ KUTU: Şeffaf arka plan, gradient kenarlık -->
                    <Border Margin="22,0,22,20"
                            BackgroundColor="Transparent"
                            StrokeThickness="3"
                            Padding="10">
                        <Border.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#60A5FA" Offset="0.0" />
                                <GradientStop Color="#A5B4FC" Offset="0.5" />
                                <GradientStop Color="#C4B5FD" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Stroke>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="28" />
                        </Border.StrokeShape>

                        <!-- İÇ KUTU: Gradient dolgulu içerik kartı -->
                        <Border StrokeThickness="0" Padding="22,24">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#BFDBFE" Offset="0.0" />
                                    <GradientStop Color="#DBEAFE" Offset="0.45" />
                                    <GradientStop Color="#EFF6FF" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>

                            <VerticalStackLayout Spacing="18">

                                <!-- FİYAT -->
                                <VerticalStackLayout Spacing="5">
                                    <HorizontalStackLayout Spacing="3" VerticalOptions="End">
                                        <Label x:Name="PriceLabel"
                                               Text="₺250,00"
                                               FontSize="32"
                                               FontAttributes="Bold"
                                               TextColor="#1E3A8A"
                                               VerticalOptions="End" />
                                        <Label Text="/ay"
                                               FontSize="14"
                                               TextColor="#3B82F6"
                                               FontAttributes="Bold"
                                               VerticalOptions="End"
                                               Margin="2,0,0,5" />
                                    </HorizontalStackLayout>
                                    <Label Text="Akıllı Ev Premium'a geçin ve evinizi tam anlamıyla kontrol altına alın."
                                           FontSize="13"
                                           TextColor="#1E40AF"
                                           Opacity="0.85"
                                           LineHeight="1.4" />
                                </VerticalStackLayout>

                                <!-- AYIRICI -->
                                <Grid ColumnDefinitions="*, Auto, *" VerticalOptions="Center">
                                    <BoxView Grid.Column="0" HeightRequest="1" Color="#93C5FD" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="Özellikler" FontSize="11" TextColor="#2563EB" Margin="10,0" FontAttributes="Bold" />
                                    <BoxView Grid.Column="2" HeightRequest="1" Color="#93C5FD" VerticalOptions="Center" />
                                </Grid>

                                <!-- ÖZELLİKLER -->
                                <VerticalStackLayout Spacing="13">
                                    <HorizontalStackLayout Spacing="12">
                                        <Image Source="seen.png" HeightRequest="17" WidthRequest="17" VerticalOptions="Center" />
                                        <Label Text="Tüm cihazlara sınırsız erişim" FontSize="14" TextColor="#1E3A8A" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="12">
                                        <Image Source="seen.png" HeightRequest="17" WidthRequest="17" VerticalOptions="Center" />
                                        <Label Text="Gelişmiş sensör istatistikleri" FontSize="14" TextColor="#1E3A8A" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="12">
                                        <Image Source="seen.png" HeightRequest="17" WidthRequest="17" VerticalOptions="Center" />
                                        <Label Text="Enerji tüketimi analizleri" FontSize="14" TextColor="#1E3A8A" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="12">
                                        <Image Source="seen.png" HeightRequest="17" WidthRequest="17" VerticalOptions="Center" />
                                        <Label Text="Akıllı mod otomasyonları" FontSize="14" TextColor="#1E3A8A" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="12">
                                        <Image Source="seen.png" HeightRequest="17" WidthRequest="17" VerticalOptions="Center" />
                                        <Label Text="Öncelikli müşteri desteği" FontSize="14" TextColor="#1E3A8A" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Border>
                    </Border>

                    <!-- SSL NOTU -->
                    <Label Text="🛡️ Ödemeleriniz Stripe tarafından 256-bit SSL ile şifrelenir."
                           TextColor="#94A3B8"
                           FontSize="11"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           Margin="30,0,30,30" />

                </VerticalStackLayout>

                <!-- PREMIUM VIEW -->
                <VerticalStackLayout x:Name="PremiumView" IsVisible="False" Spacing="0">
                    <VerticalStackLayout Padding="28,16,28,20" Spacing="10">
                        <Label Text="Hoş Geldiniz,&#x0a;Premium Üye! ✨"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="#0F172A"
                               LineHeight="1.25" />
                        <Label Text="Tüm premium avantajlar aktif. Evinizin tam kontrolü sizde."
                               FontSize="14"
                               TextColor="#64748B"
                               LineHeight="1.45" />
                    </VerticalStackLayout>

                    <Border Margin="22,0,22,30" StrokeThickness="0" Padding="30" HeightRequest="370">
                        <Border.StrokeShape><RoundRectangle CornerRadius="30" /></Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#4F46E5" Offset="0.0" />
                                <GradientStop Color="#7C3AED" Offset="0.5" />
                                <GradientStop Color="#9333EA" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="#7C3AED" Offset="0,10" Radius="28" Opacity="0.3" />
                        </Border.Shadow>
                        <VerticalStackLayout VerticalOptions="Center" Spacing="18">
                            <Label Text="✨" FontSize="60" HorizontalOptions="Center" />
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Tebrikler!" TextColor="White" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center" />
                                <Label Text="Premium Üyeliğiniz Aktif" TextColor="#C4B5FD" FontSize="15" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <BoxView HeightRequest="1" Color="#FFFFFF" Opacity="0.2" Margin="0,5" />
                            <Label Text="Evinizin tüm kontrolü artık sınırsız ve tamamen sizin elinizde."
                                   TextColor="White" FontSize="14" HorizontalTextAlignment="Center"
                                   Opacity="0.85" LineHeight="1.4" />

                            <!-- Abonelikten Çık - Kırmızı Altı Çizili -->
                            <Label Text="Abonelikten Çık"
                                   TextColor="#FCA5A5"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   TextDecorations="Underline"
                                   Margin="0,15,0,0">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCancelClicked" />
                                </Label.GestureRecognizers>
                            </Label>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ALT BUTON -->
        <Grid Grid.Row="2" x:Name="PayButtonContainer" Padding="22,12,22,38" BackgroundColor="#F5F7FA">
            <Border StrokeThickness="0" HeightRequest="58">
                <Border.StrokeShape><RoundRectangle CornerRadius="29" /></Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#4F46E5" Offset="0.0" />
                        <GradientStop Color="#7C3AED" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#4F46E5" Offset="0,6" Radius="18" Opacity="0.35" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPayButtonTapped" />
                </Border.GestureRecognizers>
                <Label Text="Premium'a Yükselt"
                       TextColor="White"
                       FontSize="17"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>
        </Grid>

        <!-- ÖDEME BAŞARILI TAM EKRAN -->
        <Grid x:Name="SuccessOverlay" Grid.RowSpan="3" IsVisible="False" BackgroundColor="#F5F7FA">
            <BoxView BackgroundColor="#F5F7FA" VerticalOptions="Fill" HorizontalOptions="Fill" />

            <!-- İçerik — referans görseldeki gibi dikey ortalanmış -->
            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Fill"
                                 Spacing="0"
                                 Padding="32,0">

                <!-- BAŞLIK BLOĞU (üstte, görselin önünde) -->
                <VerticalStackLayout Spacing="12" Margin="0,0,0,28">
                    <Label Text="Ödeme&#x0a;Tamamlandı!"
                           FontFamily="StackSansBold"
                           FontSize="46"
                           TextColor="#1A1A1A"
                           LineHeight="1.15"
                           HorizontalOptions="Start" />

                    <!-- Alt yazı: "Pro Plan" kısmı bold, geri kalanı normal -->
                    <FlexLayout Wrap="Wrap" JustifyContent="Start">
                        <Label Text="Artık "
                               FontSize="15"
                               TextColor="#6B6B6B" />
                        <Label Text="Premium Plan"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#1A1A1A" />
                        <Label Text="'dasınız! Tüm yeni"
                               FontSize="15"
                               TextColor="#6B6B6B" />
                    </FlexLayout>
                    <Label Text="özellikler kullanıma hazır."
                           FontSize="15"
                           TextColor="#6B6B6B"
                           Margin="0,-8,0,0" />
                </VerticalStackLayout>

                <!-- ANİMASYONLU GÖRSEL -->
                <Grid HeightRequest="350" HorizontalOptions="Fill">
                    <Image x:Name="SuccessImage"
                           Source="paymentsuccess.png"
                           HeightRequest="350"
                           WidthRequest="350"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Grid>

                <!-- BUTONLAR -->
                <VerticalStackLayout Spacing="18" Margin="0,32,0,0">

                    <!-- Koyu pill buton -->
                    <Border BackgroundColor="#1A1A1A"
                            StrokeThickness="0"
                            HeightRequest="60">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="30" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnGoHomeClicked" />
                        </Border.GestureRecognizers>
                        <Label Text="Anasayfaya Dön"
                               TextColor="White"
                               FontSize="17"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <!-- Altı çizili Dismiss linki -->
                    <Label Text="Fatura Görüntüle"
                           TextColor="#1A1A1A"
                           FontSize="15"
                           TextDecorations="Underline"
                           HorizontalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnViewInvoiceTapped" />
                        </Label.GestureRecognizers>
                    </Label>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
