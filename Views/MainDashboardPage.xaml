<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AkilliEvMobil.Views"
             x:Class="AkilliEvMobil.Views.MainDashboardPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="White">

    <Grid RowDefinitions="*, Auto">
        <!-- Arka Plan Açık Tema -->
        <BoxView BackgroundColor="#F5F7FA" Grid.Row="0" Grid.RowSpan="2" />

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="25">
                
                <!-- Üst Header: Profil (Yukarı Taşındı) -->
                <Grid ColumnDefinitions="Auto, *" VerticalOptions="Center" Margin="0,-5,0,0">
                    <Border Grid.Column="0" HeightRequest="50" WidthRequest="50" StrokeThickness="0" Margin="0,0,15,0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="25" /></Border.StrokeShape>
                        <Image Source="user.png" Aspect="AspectFill" BackgroundColor="#E0E0E0" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                        <Label Text="Hoşgeldiniz," TextColor="#888888" FontSize="14" />
                        <Label x:Name="UserNameLabel" Text="Yükleniyor..." TextColor="#1E293B" FontSize="20" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Sensörler (Sicaklik & Nem) ve Yağmur Verisi Kartları -->
                <Border BackgroundColor="#FFFFFF" StrokeThickness="0" Padding="8" HeightRequest="140">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="40" />
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="8">

                        <Grid Grid.Column="0" RowDefinitions="*, *" RowSpacing="8">

                            <Border Grid.Row="0" BackgroundColor="#F5F7FA" StrokeThickness="0" Padding="8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="40" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto, *" VerticalOptions="Center">
                                    <Border Grid.Column="0" BackgroundColor="#FFF4E5" HeightRequest="40" WidthRequest="40" StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="18" />
                                        </Border.StrokeShape>
                                        <Image Source="temperature.png" HeightRequest="40" WidthRequest="40" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Margin="10,0,0,0" VerticalOptions="Center">
                                        <Label Text="Sıcaklık" TextColor="#A0AABF" FontSize="11" />
                                        <Label x:Name="TempLabel" Text="24°" TextColor="#1E293B" FontSize="16" FontAttributes="Bold" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" BackgroundColor="#F5F7FA" StrokeThickness="0" Padding="8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="40" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto, *" VerticalOptions="Center">
                                    <Border Grid.Column="0" BackgroundColor="#F3E8FF" HeightRequest="40" WidthRequest="40" StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="18" />
                                        </Border.StrokeShape>
                                        <Image Source="humidity.png" HeightRequest="40" WidthRequest="40" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Margin="10,0,0,0" VerticalOptions="Center">
                                        <Label Text="Nem Verisi" TextColor="#A0AABF" FontSize="11" />
                                        <Label x:Name="HumidityLabel" Text="45%" TextColor="#1E293B" FontSize="16" FontAttributes="Bold" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Column="1" StrokeThickness="0" Padding="15" VerticalOptions="Fill">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                    <GradientStop Color="#357ABD" Offset="0.0" />
                                    <GradientStop Color="#6FB4F8" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="30" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnWeatherCardTapped" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="0">
                                <Image x:Name="WeatherImage" Source="https://openweathermap.org/img/wn/01d@2x.png" HeightRequest="55" WidthRequest="55" HorizontalOptions="Center" />
                                <Label x:Name="WeatherTempLabel" Text="24°C" TextColor="#FFFFFF" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,-5,0,0" />
                                <Label x:Name="CityLabel" Text="İzmit" TextColor="#D1E4FA" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,-4,0,0" />
                            </VerticalStackLayout>
                        </Border>

                    </Grid>
                </Border>

                <!-- Aktif Cihazlar ve Modlar -->
                <Grid ColumnDefinitions="*, 210" ColumnSpacing="15" Padding="0" Margin="0">
                    <!-- Aktif Cihazlar -->
                    <Border Grid.Column="0" StrokeThickness="0" Margin="0" Padding="0" HeightRequest="140" VerticalOptions="Fill">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#5bff14" Offset="0.0" />
                                <GradientStop Color="#36b002" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="35" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Padding="0" Margin="0"  VerticalOptions="Center" HorizontalOptions="Center" Spacing="13">
                            <Image Source="thunderbolt.png" HeightRequest="38" TranslationY="0" />
                            <Label x:Name="ActiveDeviceCountLabel" Text="1 Cihaz" TextColor="#FFFFFF" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center"  />
                            <Label Text="Aktif" TextColor="#E2FBEA" FontSize="12" HorizontalOptions="Center" TranslationY="2"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Modlar: İyi Geceler ve Günaydın -->
                    <VerticalStackLayout Grid.Column="1" Spacing="10" HorizontalOptions="Fill">
                        <!-- İyi Geceler Modu -->
                        <Border StrokeThickness="0" Padding="0" HeightRequest="65">
                            <Border.StrokeShape><RoundRectangle CornerRadius="32" /></Border.StrokeShape>
                            <Grid>
                                <Image Source="goodnightmodebg.jpg" Aspect="AspectFill" />
                                <HorizontalStackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Start" Margin="10,0">
                                    <Border BackgroundColor="Transparent" StrokeThickness="0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="25" /></Border.StrokeShape>
                                        <Image Source="night.png" HeightRequest="50" WidthRequest="50" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Label Text="İyi Geceler" TextColor="White" FontSize="15" FontAttributes="Bold" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>

                        <!-- Günaydın Modu -->
                        <Border BackgroundColor="#FFFFFF" StrokeThickness="0" Padding="5" HeightRequest="65">
                            <Border.StrokeShape><RoundRectangle CornerRadius="32" /></Border.StrokeShape>
                            <HorizontalStackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Start" Margin="5,0">
                                <Border BackgroundColor="Transparent" StrokeThickness="0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="25" /></Border.StrokeShape>
                                    <Image Source="morning.png" HeightRequest="50" WidthRequest="50" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="Günaydın" TextColor="#1E293B" FontSize="15" FontAttributes="Bold" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <!-- Favori Cihazlar -->
                <VerticalStackLayout Spacing="15" Margin="0,10,0,10">
                    <Label Text="Favori Cihazlar" TextColor="#1E293B" FontSize="18" FontAttributes="Bold" />
                    
                    <CollectionView ItemsSource="{Binding FavoriteDevices}" HeightRequest="200" HorizontalOptions="Center">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="15"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.EmptyView>
                            <Label Text="Henüz favori cihaz eklenmedi." TextColor="#A0AABF" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,20" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="White" StrokeThickness="0" WidthRequest="160" HeightRequest="180">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                    <Border.Shadow><Shadow Brush="#000000" Offset="0,4" Radius="10" Opacity="0.05" /></Border.Shadow>
                                    <Grid Padding="15">
                                        <!-- Favorite Icon -->
                                        <Image Source="{Binding FavoriteIcon}" 
                                               HorizontalOptions="End" 
                                               VerticalOptions="Start" 
                                               HeightRequest="25" 
                                               WidthRequest="25"
                                               Margin="0,-5,-5,0">
                                            <Image.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnFavoriteTapped" />
                                            </Image.GestureRecognizers>
                                        </Image>
                                        
                                        <VerticalStackLayout VerticalOptions="End" Spacing="5">
                                            <Image Source="{Binding ImageSource}" HeightRequest="100" TranslationY="-20" />
                                            <Label Text="{Binding Name}" FontSize="16" HorizontalTextAlignment="Center" FontAttributes="Bold" TextColor="#1E293B" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- YENİ MODÜLER CUSTOM TAB BAR KONTROLÜ (TÜM SAYFALAR İÇİN ORTAK) -->
        <local:CustomTabBar Grid.Row="1" ActiveTab="Home" />
    </Grid>
</ContentPage>
