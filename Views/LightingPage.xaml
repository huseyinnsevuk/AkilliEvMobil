<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AkilliEvMobil.Views"
             xmlns:controls="clr-namespace:AkilliEvMobil.Views.Controls"
             x:Class="AkilliEvMobil.Views.LightingPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#F5F7FA">

    <Grid RowDefinitions="Auto, *">
        <!-- Header (Fixed at top) -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="15,40,15,20" BackgroundColor="#F5F7FA" ZIndex="1">
            <Border Grid.Column="0" HeightRequest="44" WidthRequest="44" BackgroundColor="White" StrokeThickness="0" HorizontalOptions="Start" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape>
                <Border.Shadow><Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.05" /></Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked" />
                </Border.GestureRecognizers>
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="Scale" Value="0.9" />
                                    <Setter Property="BackgroundColor" Value="#F0F3F8" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
                <Image Source="back.png" HeightRequest="18" WidthRequest="18" TranslationX="-3" VerticalOptions="Center" HorizontalOptions="Center" InputTransparent="True" />
            </Border>
            <Label Grid.Column="1" Text="Aydınlatma" FontFamily="Quicksand" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#1E293B" />
            <BoxView Grid.Column="2" WidthRequest="44" BackgroundColor="Transparent" />
        </Grid>

        <!-- Scrollable Content -->
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="0,0,0,100">
                <!-- Lamp Image Section -->
                <Grid VerticalOptions="Center" HorizontalOptions="Center" Margin="0,20">
                    <!-- Dynamic Glow -->
                    <Ellipse x:Name="GlowEffect" Fill="#FFD54F" Opacity="0.15" HeightRequest="300" WidthRequest="300" IsVisible="True">
                        <Ellipse.Shadow>
                            <Shadow Brush="#FFD54F" Offset="0,0" Radius="100" Opacity="0.6" />
                        </Ellipse.Shadow>
                    </Ellipse>
                    
                    <Image Source="light.png" HeightRequest="350" Aspect="AspectFit" VerticalOptions="Center" />
                </Grid>

                <!-- Status Card -->
                <Border Margin="25,0,25,30" BackgroundColor="White" StrokeThickness="0" Padding="20">
                    <Border.StrokeShape><RoundRectangle CornerRadius="30" /></Border.StrokeShape>
                    <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="15" Opacity="0.03" /></Border.Shadow>
                    
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Ana Aydınlatma" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" />
                            <Label x:Name="StatusLabel" Text="Şu an açık" FontSize="14" TextColor="#A0AABF" />
                        </VerticalStackLayout>
                        
                        <Switch Grid.Column="1" IsToggled="True" Toggled="OnLightToggled" Scale="1.2" ThumbColor="#FFB300" OnColor="#FFE082">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroupList>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="On">
                                            <VisualState.Setters>
                                                <Setter Property="ThumbColor" Value="#FFB300" />
                                                <Setter Property="OnColor" Value="#FFE082" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Off">
                                            <VisualState.Setters>
                                                <Setter Property="ThumbColor" Value="#BDBDBD" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateGroupList>
                            </VisualStateManager.VisualStateGroups>
                        </Switch>
                    </Grid>
                </Border>

                <!-- Slider Section -->
                <VerticalStackLayout Padding="25,0,25,20" Spacing="25">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="Parlaklık Seviyesi" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" />
                        <Label Grid.Column="1" x:Name="BrightnessLabel" Text="80%" FontSize="18" FontAttributes="Bold" TextColor="#FFB300" />
                    </Grid>
                    
                    <controls:StripedSlider x:Name="BrightnessSlider" Value="80" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
