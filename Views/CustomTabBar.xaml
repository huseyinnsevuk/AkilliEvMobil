<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AkilliEvMobil.Views.CustomTabBar">
    
    <!-- YÜZEN (PILL) ALT MENÜ KAPSÜLÜ -->
    <Border BackgroundColor="#dfe6f0" StrokeThickness="0" Padding="8" Margin="20,0,20,20" HeightRequest="70">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="35" />
        </Border.StrokeShape>
        <Border.Shadow>
            <Shadow Brush="#000000" Offset="0,10" Radius="20" Opacity="0.1" />
        </Border.Shadow>
        
        <Grid ColumnDefinitions="*, *, *, *">
            
            <!-- HOME -->
            <Border x:Name="HomeBorder" Grid.Column="0" BackgroundColor="#FFFFFF" HeightRequest="54" WidthRequest="54" StrokeThickness="0" HorizontalOptions="Center" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="27" /></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </Border.GestureRecognizers>
                <Image x:Name="HomeImage" Source="home_off.png" HeightRequest="26" WidthRequest="26" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            
            <!-- GRID (All Devices) -->
            <Border x:Name="GridBorder" Grid.Column="1" BackgroundColor="#FFFFFF" HeightRequest="54" WidthRequest="54" StrokeThickness="0" HorizontalOptions="Center" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="27" /></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnGridTapped" />
                </Border.GestureRecognizers>
                <Image x:Name="GridImage" Source="grid_off.png" HeightRequest="26" WidthRequest="26" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <!-- AUTOMATION -->
            <Border x:Name="AutomationBorder" Grid.Column="2" BackgroundColor="#FFFFFF" HeightRequest="54" WidthRequest="54" StrokeThickness="0" HorizontalOptions="Center" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="27" /></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAutomationTapped" />
                </Border.GestureRecognizers>
                <Image x:Name="AutomationImage" Source="automation_off.png" HeightRequest="26" WidthRequest="26" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <!-- SETTINGS -->
            <Border x:Name="SettingsBorder" Grid.Column="3" BackgroundColor="#FFFFFF" HeightRequest="54" WidthRequest="54" StrokeThickness="0" HorizontalOptions="Center" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="27" /></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSettingsTapped" />
                </Border.GestureRecognizers>
                <Image x:Name="SettingsImage" Source="settings_off.png" HeightRequest="26" WidthRequest="26" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

        </Grid>
    </Border>
</ContentView>
